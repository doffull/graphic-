{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Generation": {
      "title": "Generation",
      "description": "A generated micro-graphic image and its parameters",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who generated this" },
        "prompt": { "type": "string", "description": "The prompt used for generation" },
        "theme": { "type": "string", "description": "The theme used" },
        "visualStyle": { "type": "string", "description": "The visual style used" },
        "colorPalette": { "type": "string", "description": "The color palette used" },
        "fineness": { "type": "number", "description": "The fineness level" },
        "density": { "type": "number", "description": "The density level" },
        "aspectRatio": { "type": "string", "description": "The aspect ratio" },
        "imageThumb": { "type": "string", "description": "Base64 encoded thumbnail image" },
        "imageFull": { "type": "string", "description": "Base64 encoded full image (if fits in 1MB)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the generation was created" }
      },
      "required": ["userId", "prompt", "theme", "visualStyle", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/generations/{generationId}": {
      "schema": { "$ref": "#/entities/Generation" },
      "description": "Stores generated images and parameters"
    }
  }
}
